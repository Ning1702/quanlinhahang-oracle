@model Quanlinhahang.Data.Models.HoaDon

@{
    ViewData["Title"] = "Cập nhật hóa đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Cập nhật Hóa đơn #@Model.HoaDonId</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="HoaDonId" />

                <div class="mb-3">
                    <label class="form-label">VAT (%)</label>
                    <input asp-for="Vatpercent" class="form-control" type="number" step="0.01" min="0" max="100" placeholder="Ví dụ: 10 cho 10%" />
                </div>

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>