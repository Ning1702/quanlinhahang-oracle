@model IEnumerable<Quanlinhahang.Data.Models.MonAn>
@{
    ViewData["Title"] = "Quản lý món ăn";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css" />
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<a asp-controller="Home" asp-action="Index" class="exit-square">✕</a>

<div class="container mt-4">
    <h2 class="text-center fw-bold mb-4">Quản lý món ăn</h2>

    <div class="filter-card shadow-sm p-4 mb-4">
        <form method="get" asp-action="Index">
            <div class="mb-3">
                <label class="fw-semibold">Lọc theo danh mục</label>
                <select name="DanhMucID" class="form-select">
                    <option value="">-- Tất cả danh mục --</option>
                    @foreach (var dm in (ViewBag.DanhMucList as List<Quanlinhahang.Data.Models.DanhMucMon> ?? new List<Quanlinhahang.Data.Models.DanhMucMon>()))
                    {
                        <option value="@dm.DanhMucId">@dm.TenDanhMuc</option>
                    }
                </select>
            </div>
            <div class="d-flex justify-content-center mt-3">
                <button class="btn btn-primary px-5 fw-semibold"><i class="fa fa-search"></i> Tìm kiếm</button>
            </div>
        </form>
    </div>

    <div class="d-flex justify-content-center mb-3">
        <a asp-controller="MonAns" asp-action="Create" class="btn btn-success px-4 fw-semibold" style="border-radius:8px;">
            <i class="fa fa-plus"></i> Thêm món
        </a>
    </div>

    <table class="table table-bordered table-striped text-center align-middle shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Ảnh</th>
                <th>Tên món</th>
                <th>Đơn giá</th>
                <th>Danh mục</th>
                <th>Trạng thái</th>
                <th>Hành động</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="6" class="text-muted py-3">Không có món ăn nào.</td></tr>
            }
            else
            {
                foreach (var mon in Model)
                {
                    <tr id="row-@mon.MonAnId">
                        <td>
                            @{
                                // LOGIC CHỌN FOLDER (Giống code Menu của bạn)
                                string folder = "Monan"; // Mặc định

                                // Nếu là Combo/Set thì chuyển folder
                                if ((!string.IsNullOrEmpty(mon.LoaiMon) && mon.LoaiMon.Contains("Combo")) ||
                                (mon.DanhMuc != null && (mon.DanhMuc.TenDanhMuc.Contains("Set") || mon.DanhMuc.TenDanhMuc.Contains("Combo"))))
                                {
                                    folder = "Setmonan";
                                }

                                string imgName = !string.IsNullOrEmpty(mon.HinhAnhUrl) ? mon.HinhAnhUrl : "default.jpg";
                                // ĐƯỜNG DẪN DÙNG /shared/
                                string imgPath = $"/shared/{folder}/{imgName}";
                            }

                            <img src="@imgPath"
                                 style="width:70px;height:70px;border-radius:8px;cursor:pointer;object-fit:cover"
                                 onclick="zoomImage('@imgPath')"
                                 onerror="this.src='/shared/Monan/default.jpg'" />
                        </td>
                        <td>@mon.TenMon</td>
                        <td>@String.Format("{0:N0} ₫", mon.DonGia)</td>
                        <td>@mon.DanhMuc?.TenDanhMuc</td>
                        <td>@mon.TrangThai</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@mon.MonAnId" class="btn btn-warning btn-sm fw-semibold"><i class="fa-solid fa-pen-to-square"></i></a>
                            <button type="button" class="btn btn-danger btn-sm fw-semibold" onclick="confirmDelete(@mon.MonAnId)"><i class="fa-solid fa-trash"></i></button>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <div class="d-flex justify-content-center my-4">
        <div class="stat-box shadow-sm">
            <div class="fw-bold fs-4 text-dark text-center">Tổng số món: @Model.Count()</div>
        </div>
    </div>
</div>

@if (TempData["msg"] != null)
{
    <script>document.addEventListener("DOMContentLoaded", () => { Swal.fire({ icon: 'success', title: '@TempData["msg"]', showConfirmButton: false, timer: 1600 }); });</script>
}

<script>
    function confirmDelete(id) {
        Swal.fire({
            title: 'Xóa món này?', icon: 'warning', showCancelButton: true, confirmButtonColor: '#d33', confirmButtonText: 'Xóa', cancelButtonText: 'Hủy'
        }).then((result) => {
            if (result.isConfirmed) {
                fetch('/MonAns/DeleteConfirmed?id=' + id, { method: 'POST' })
                    .then(res => {
                        if (!res.ok) { Swal.fire("Lỗi", "Không thể xóa", "error"); return; }
                        document.getElementById("row-" + id)?.remove();
                        Swal.fire({ icon: 'success', title: 'Đã xóa!', timer: 1000, showConfirmButton: false });
                    });
            }
        });
    }
    function zoomImage(url) {
        Swal.fire({ imageUrl: url, showConfirmButton: false, background: '#000000d9', width: 500 });
    }
</script>

<style>
    body {
        background-color: #f8f9fa;
    }

    .container {
        background: #fff;
        padding: 30px;
        border-radius: 16px;
        box-shadow: 0 6px 25px rgba(0,0,0,0.08);
    }

    .filter-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e1e1e1;
    }

    .exit-square {
        position: fixed;
        top: 20px;
        right: 25px;
        width: 40px;
        height: 40px;
        background: #dc3545;
        color: white !important;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        text-decoration: none;
        z-index: 9999;
    }
</style>