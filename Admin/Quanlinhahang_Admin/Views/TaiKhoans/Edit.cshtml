@model Quanlinhahang.Data.Models.TaiKhoan
@using Quanlinhahang.Data.Models

@{
    ViewData["Title"] = "Cập nhật tài khoản";
}

<div class="container mt-4" style="max-width: 600px">
    <div class="card shadow">
        <div class="card-header bg-warning">
            <h4 class="mb-0">Cập nhật Tài khoản: @Model.TenDangNhap</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="TaiKhoanId" />
                <input type="hidden" asp-for="TenDangNhap" /> @* Không cho sửa Username *@

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" type="email" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Vai trò</label>
                    <select asp-for="VaiTro" class="form-select">
                        <option value="Admin">Admin</option>
                        <option value="Staff">Staff</option>
                        <option value="Customer">Customer</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label">Trạng thái</label>
                    <select asp-for="TrangThai" class="form-select">
                        <option value="Hoạt động">Hoạt động</option>
                        <option value="Khóa">Khóa</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label text-danger">Đổi mật khẩu (Bỏ trống nếu không đổi)</label>
                    <input name="NewPassword" type="password" class="form-control" placeholder="Nhập mật khẩu mới..." />
                </div>

                <div class="text-end">
                    <a asp-action="Index" class="btn btn-secondary">Hủy</a>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>