@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    ViewData["Title"] = "Thống kê doanh số";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Báo cáo thống kê</title>

    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/css/adminlte.min.css">

    <style>
        /* Nút X đỏ */
        .exit-square {
            position: fixed;
            top: 20px;
            right: 25px;
            width: 42px;
            height: 42px;
            background: #dc3545;
            color: white !important;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            font-weight: bold;
            text-decoration: none;
            box-shadow: 0 4px 8px rgba(0,0,0,0.25);
            z-index: 9999;
            transition: 0.15s;
        }

            .exit-square:hover {
                background: #b02a37;
                transform: scale(1.05);
            }
    </style>

</head>
<body class="hold-transition sidebar-mini" style="background-color: #f4f6f9;">

    <!-- Nút quay lại -->
    <a asp-controller="Home" asp-action="Index" class="exit-square">✕</a>

    <div class="wrapper">
        <div class="content-wrapper" style="margin-left: 0 !important; min-height: 100vh;">

            <section class="content-header">
                <div class="container-fluid">
                    <div class="row mb-2">
                        <div class="col-sm-12 text-center">
                            <h2 class="font-weight-bold text-uppercase mt-3">Báo cáo hoạt động kinh doanh</h2>
                        </div>
                    </div>
                </div>
            </section>

            <section class="content">
                <div class="container-fluid" style="max-width: 1000px;">

                    <!-- =================== DOANH THU QUÝ =================== -->
                    <div class="row">
                        <div class="col-md-3 col-6">
                            <div class="small-box bg-info">
                                <div class="inner">
                                    <h4 id="q1Val">0</h4>
                                    <p>Quý 1</p>
                                </div>
                                <div class="icon"><i class="fas fa-chart-bar"></i></div>
                            </div>
                        </div>

                        <div class="col-md-3 col-6">
                            <div class="small-box bg-success">
                                <div class="inner">
                                    <h4 id="q2Val">0</h4>
                                    <p>Quý 2</p>
                                </div>
                                <div class="icon"><i class="fas fa-chart-line"></i></div>
                            </div>
                        </div>

                        <div class="col-md-3 col-6">
                            <div class="small-box bg-warning">
                                <div class="inner">
                                    <h4 id="q3Val">0</h4>
                                    <p>Quý 3</p>
                                </div>
                                <div class="icon"><i class="fas fa-shopping-cart"></i></div>
                            </div>
                        </div>

                        <div class="col-md-3 col-6">
                            <div class="small-box bg-danger">
                                <div class="inner">
                                    <h4 id="q4Val">0</h4>
                                    <p>Quý 4</p>
                                </div>
                                <div class="icon"><i class="fas fa-pie-chart"></i></div>
                            </div>
                        </div>
                    </div>

                    <!-- =================== DOANH THU 12 THÁNG =================== -->
                    <div class="card card-primary card-outline mb-4">
                        <div class="card-header">
                            <h3 class="card-title font-weight-bold">
                                <i class="fas fa-chart-bar mr-1"></i> Doanh thu 12 tháng gần nhất
                            </h3>
                        </div>

                        <div class="card-body">
                            <div style="height: 350px;">
                                <canvas id="revenueChart"></canvas>
                            </div>
                            <div class="mt-3 text-center font-weight-bold text-muted">
                                Tổng doanh thu năm <span id="sumYearLabel"></span>:
                                <span id="sumYearVal" class="text-primary">0 đ</span>
                            </div>
                        </div>
                    </div>

                    <!-- =================== NHÂN VIÊN XUẤT SẮC =================== -->
                    <div class="card card-widget widget-user-2 mb-4 shadow-sm" id="bestEmpCard" style="display:none;">
                        <div class="widget-user-header bg-warning">

                            <h3 class="widget-user-username font-weight-bold">
                                <span id="bestEmpName">---</span>
                                <span class="badge bg-dark ml-2" id="bestEmpID">ID: ---</span>
                            </h3>

                            <h5 class="widget-user-desc">Nhân Viên Xuất Sắc Nhất</h5>
                        </div>

                        <div class="card-footer p-0">
                            <ul class="nav flex-column">

                                <li class="nav-item">
                                    <span class="nav-link">
                                        Số lượng bán được
                                        <span class="float-right badge bg-primary" style="font-size:1rem;" id="bestEmpOrders">0</span>
                                    </span>
                                </li>

                                <li class="nav-item">
                                    <span class="nav-link">
                                        Tổng doanh thu
                                        <span class="float-right badge bg-info" style="font-size:1rem;" id="bestEmpRevenue">0 đ</span>
                                    </span>
                                </li>

                            </ul>
                        </div>
                    </div>

                    <div id="noEmpData" class="alert alert-warning mb-4" style="display:none;">
                        <i class="icon fas fa-exclamation-triangle"></i> Chưa có dữ liệu nhân viên.
                    </div>

                    <!-- =================== TOP 3 KHÁCH HÀNG =================== -->
                    <div class="card mb-4">
                        <div class="card-header border-0 bg-navy">
                            <h3 class="card-title font-weight-bold">Top 3 Khách Hàng Thân Thiết</h3>
                        </div>
                        <div class="card-body table-responsive p-0">
                            <table class="table table-striped table-valign-middle">
                                <thead>
                                    <tr>
                                        <th>Khách hàng</th>
                                        <th>SĐT</th>
                                        <th class="text-right">Chi tiêu</th>
                                        <th class="text-center">Hạng</th>
                                    </tr>
                                </thead>
                                <tbody id="topCustomerTable"></tbody>
                            </table>
                        </div>
                    </div>

                    <!-- =================== TỈ LỆ TÀI KHOẢN =================== -->
                    <div class="card card-success card-outline mb-5">
                        <div class="card-header">
                            <h3 class="card-title font-weight-bold">
                                <i class="fas fa-users mr-1"></i> Tỷ lệ khách hàng có tài khoản
                            </h3>
                        </div>
                        <div class="card-body">
                            <div class="row">

                                <div class="col-md-7">
                                    <canvas id="accountPercentChart" height="220"></canvas>
                                </div>

                                <div class="col-md-5 d-flex flex-column justify-content-center align-items-center">
                                    <ul class="chart-legend clearfix text-secondary">
                                        <li><i class="far fa-circle text-success"></i> Đã có tài khoản</li>
                                        <li><i class="far fa-circle text-danger"></i> Khách vãng lai</li>
                                    </ul>

                                    <div id="accountInfo" class="mt-3 font-weight-bold text-center"></div>
                                </div>

                            </div>
                        </div>
                    </div>

                </div>
            </section>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/admin-lte@3.2/dist/js/adminlte.min.js"></script>

    <script>
        const nf = n => Number(n || 0).toLocaleString('vi-VN') + ' đ';

        $(function () {

            /* ================= 12 THÁNG ================= */
            $.get('@Url.Action("RevenueLast12Months")', function (rev) {
                new Chart(document.getElementById('revenueChart'), {
                    type: 'bar',
                    data: {
                        labels: rev.map(x => x.label),
                        datasets: [{
                            backgroundColor: '#007bff',
                            data: rev.map(x => x.value)
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            y: { beginAtZero: true }
                        }
                    }
                });
            });

            /* ================= QUÝ ================= */
            $.get('@Url.Action("RevenueQuarterAndYear")', function (q) {
                $('#q1Val').text(nf(q.q1));
                $('#q2Val').text(nf(q.q2));
                $('#q3Val').text(nf(q.q3));
                $('#q4Val').text(nf(q.q4));

                $('#sumYearLabel').text(q.year);
                $('#sumYearVal').text(nf(q.yearTotal));
            });

            /* ================= NHÂN VIÊN ================= */
            $.get('@Url.Action("BestEmployee")', function (emp) {

                if (emp && emp.countOrders > 0) {
                    $('#bestEmpCard').show();
                    $('#noEmpData').hide();

                    $('#bestEmpName').text(emp.hoTen);
                    $('#bestEmpID').text("ID: " + emp.nhanVienID);

                    $('#bestEmpOrders').text(emp.countOrders + " đơn");
                    $('#bestEmpRevenue').text(nf(emp.totalRevenue));

                } else {
                    $('#bestEmpCard').hide();
                    $('#noEmpData').show();
                }
            });

            /* ================= TOP KHÁCH ================= */
            $.get('@Url.Action("TopCustomers")', function (list) {

                let html = "";
                const rankColors = ["danger", "warning", "info"];

                list.forEach((c, i) => {
                    html += `
                        <tr>
                            <td>${c.tenKhachHang}</td>
                            <td>${c.soDienThoai || "-"}</td>
                            <td class="text-right text-success font-weight-bold">${nf(c.totalSpent)}</td>
                            <td class="text-center"><span class="badge bg-${rankColors[i]}">Top ${i + 1}</span></td>
                        </tr>`;
                });

                $('#topCustomerTable').html(html);
            });

            /* ================= ACCOUNT PERCENT ================= */
            $.get('@Url.Action("CustomerAccountPercent")', function (p) {

                let have = p.coTaiKhoan;
                let not = p.totalKH - have;

                $('#accountInfo').text(`Tổng: ${p.totalKH} - Đã có TK: ${have} (${p.percent}%)`);

                new Chart(document.getElementById('accountPercentChart'), {
                    type: 'pie',
                    data: {
                        labels: ['Đã có tài khoản', 'Khách vãng lai'],
                        datasets: [{
                            data: [have, not],
                            backgroundColor: ['#28a745', '#dc3545']
                        }]
                    }
                });
            });

        });
    </script>

</body>
</html>
