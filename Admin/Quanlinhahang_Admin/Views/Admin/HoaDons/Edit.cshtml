@model Quanlinhahang.Data.Models.Hoadon

@{
    ViewData["Title"] = "Cập nhật hóa đơn";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Cập nhật Hóa đơn #@Model.Hoadonid</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Hoadonid" />

                <div class="mb-3">
                    <label class="form-label">VAT (0.1 = 10%)</label>
                    <input asp-for="Vat" class="form-control" type="number" step="0.01" min="0" max="1" />
                </div>

                @* Nếu Database chưa có cột LoaiDichVu, hãy comment đoạn này lại để tránh lỗi *@
                @* <div class="mb-3">
                    <label class="form-label">Loại dịch vụ</label>
                    <select asp-for="Loaidichvu" class="form-select">
                        <option value="Tại chỗ">Tại chỗ</option>
                        <option value="Mang về">Mang về</option>
                    </select>
                </div> 
                *@

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
                    <button type="submit" class="btn btn-primary">Lưu thay đổi</button>
                </div>
            </form>
        </div>
    </div>
</div>