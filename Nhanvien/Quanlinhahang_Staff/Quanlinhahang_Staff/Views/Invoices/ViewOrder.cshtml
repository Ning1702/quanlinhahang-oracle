@model Quanlinhahang.Data.Models.Hoadon
@{
    // Sửa: HoaDonID -> Hoadonid
    ViewData["Title"] = $"Đơn đặt bàn #{Model.Hoadonid}";
}

<h2 class="mt-3">Đơn đặt bàn #@Model.Hoadonid</h2>

<div class="row mt-3">
    <div class="col-md-5">
        <h5>Thông tin đặt bàn</h5>
        <table class="table table-borderless">
            <tr>
                <th style="width:150px">Ngày đến</th>
                <td>@(Model.Datban != null ? Model.Datban.Ngayden.ToString("dd/MM/yyyy") : "---")</td>
            </tr>
            <tr>
                <th>Khung giờ (ID)</th>
                @* Sửa: KhungGioID -> Khunggioid *@
                <td>@Model.Datban?.Khunggioid</td>
            </tr>
            <tr>
                <th>Số người</th>
                <td>@Model.Datban?.Songuoi</td>
            </tr>
            <tr>
                <th>Bàn / Phòng (ID)</th>
                @* Sửa: BanPhongID -> Banphongid *@
                <td>@Model.Datban?.Banphongid</td>
            </tr>
            <tr>
                <th>Ghi chú</th>
                <td>@Model.Datban?.Yeucaudacbiet</td>
            </tr>
        </table>
    </div>

    <div class="col-md-7">
        <h5>Danh sách món khách đặt</h5>
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Tên món</th>
                    <th style="width:90px; text-align:center;">SL</th>
                    <th class="text-end" style="width:140px;">Đơn giá</th>
                    <th class="text-end" style="width:160px;">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Chitiethoadons != null)
                {
                    foreach (var ct in Model.Chitiethoadons)
                    {
                        <tr>
                            <td>@(ct.Monan?.Tenmon ?? "Món đã xóa")</td>

                            <td style="text-align:center;">@ct.Soluong</td>

                            <td class="text-end">@ct.Dongia.ToString("#,##0")</td>

                            <td class="text-end">@((ct.Soluong * ct.Dongia).ToString("#,##0"))</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

<a class="btn btn-secondary mt-3" href="@Url.Action("Index", "Invoices")">Quay lại</a>