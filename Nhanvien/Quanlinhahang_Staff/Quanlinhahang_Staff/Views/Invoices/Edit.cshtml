@model Quanlinhahang_Staff.Models.ViewModels.InvoiceEditVM
@using Microsoft.AspNetCore.Mvc.Rendering
@using Quanlinhahang.Data.Models
@{
    // CHUẨN HÓA: Sử dụng PascalCase theo Model SQL Server mới
    var monAnList = (List<MonAn>)ViewBag.MonAn;
    ViewData["Title"] = $"Sửa hóa đơn #{Model.HoaDonID}";

    bool daThanhToan = (bool)(ViewBag.DaThanhToan ?? false);
    bool khongTheSua = daThanhToan;

    // Tìm tên bàn đã chọn ban đầu
    var banPhongDaChon = ((List<BanPhong>)ViewBag.BanPhongs)
                            .FirstOrDefault(b => b.BanPhongId == Model.BanPhongID);
    var tenBanDaChon = banPhongDaChon != null ? banPhongDaChon.TenBanPhong : "Không yêu cầu";
}

<h2 class="mt-3">Hóa đơn #@Model.HoaDonID</h2>

@if (TempData["msg"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["msg"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    @* --- CỘT TRÁI: CHI TIẾT MÓN ĂN --- *@
    <div class="col-md-7">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Danh sách món đã đặt</h5>
            </div>
            <div class="card-body">
                <table class="table table-hover" id="tableItems">
                    <thead class="table-light">
                        <tr>
                            <th>Tên món</th>
                            <th style="width:150px;text-align:center">Số lượng</th>
                            <th class="text-end" style="width:160px">Đơn giá</th>
                            <th class="text-end">Thành tiền</th>
                            <th style="width:80px"></th>
                        </tr>
                    </thead>
                    <tbody id="itemsBody">
                        @foreach (var i in Model.Items)
                        {
                            <tr data-id="@i.MonAnID" data-ten="@i.TenMon" data-gia="@i.DonGia" data-sl="@i.SoLuong">
                                <td>@i.TenMon</td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2 btn-minus">-</button>
                                        <span class="mx-3 fw-bold sl-val">@i.SoLuong</span>
                                        <button type="button" class="btn btn-sm btn-outline-secondary px-2 btn-plus">+</button>
                                    </div>
                                </td>
                                <td class="text-end">@i.DonGia.ToString("#,0")đ</td>
                                <td class="text-end thanh-tien">@((i.SoLuong * i.DonGia).ToString("#,0"))đ</td>
                                <td>
                                    <button type="button" class="btn btn-sm btn-outline-danger btn-remove-all">Xóa</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light">
                        <tr>
                            <td colspan="3" class="text-end fw-bold">Tạm tính:</td>
                            <td class="text-end fw-bold" id="subTotal"></td>
                            <td></td>
                        </tr>
                        <tr>
                            <td colspan="3" class="text-end">VAT (10%):</td>
                            <td class="text-end" id="vat"></td>
                            <td></td>
                        </tr>
                        <tr class="h5">
                            <td colspan="3" class="text-end fw-bold text-primary">Tổng thanh toán:</td>
                            <td class="text-end fw-bold text-primary" id="finalTotal"></td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>

                @if (!khongTheSua)
                {
                    <div class="row g-2 mt-3 p-2 border rounded bg-light">
                        <div class="col-md-7">
                            <select class="form-select" id="addItemSelect">
                                <option value="">-- Thêm món mới --</option>
                                @foreach (var m in monAnList)
                                {
                                    <option value="@m.MonAnId" data-ten="@m.TenMon" data-gia="@m.DonGia">
                                        @m.TenMon (@m.DonGia?.ToString("#,0")đ)
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <input type="number" id="addItemSL" class="form-control" min="1" value="1" />
                        </div>
                        <div class="col-md-2">
                            <button type="button" id="btnAddItem" class="btn btn-primary w-100">Thêm</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>

    @* --- CỘT PHẢI: THÔNG TIN THANH TOÁN --- *@
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">Thông tin phục vụ & Thanh toán</h5>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Save" asp-controller="Invoices" id="paymentForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="HoaDonID" />
                    <input type="hidden" asp-for="DatBanID" />
                    <input type="hidden" asp-for="BanPhongID" id="selectedBanPhongID" />
                    <input type="hidden" name="status" value="@ViewBag.Status" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Bàn / Phòng phục vụ</label>
                        <div class="input-group">
                            <input type="text" id="selectedBanPhongName" class="form-control fw-bold" value="@tenBanDaChon" readonly />
                            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal" data-bs-target="#banPhongModal" @(daThanhToan ? "disabled" : "")>
                                <i class="fa fa-th"></i> Đổi bàn
                            </button>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ngày phục vụ</label>
                            <input type="date" class="form-control" id="txtNgayDen" name="NewNgayDen" value="@ViewBag.NgayDenVal" @(daThanhToan ? "readonly" : "") />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Khung giờ</label>
                            <select class="form-select" id="ddlKhungGio" name="NewKhungGioID" @(daThanhToan ? "disabled" : "")>
                                @if (ViewBag.ListKhungGio != null)
                                {
                                    foreach (var kg in ViewBag.ListKhungGio)
                                    {
                                        var type = kg.GetType();

                                        var id = type.GetProperty("KhungGioId")?.GetValue(kg)
                                        ?? type.GetProperty("Khunggioid")?.GetValue(kg);

                                        var ten = type.GetProperty("TenKhungGio")?.GetValue(kg)
                                        ?? type.GetProperty("Tenkhunggio")?.GetValue(kg);

                                        var gioBatDauObj = type.GetProperty("GioBatDau")?.GetValue(kg)
                                        ?? type.GetProperty("Giobatdau")?.GetValue(kg);

                                        var gioKetThucObj = type.GetProperty("GioKetThuc")?.GetValue(kg)
                                        ?? type.GetProperty("Gioketthuc")?.GetValue(kg);

                                        string gioBatDau = gioBatDauObj?.ToString()?.Length >= 5
                                        ? gioBatDauObj.ToString()!.Substring(0, 5)
                                        : gioBatDauObj?.ToString() ?? "";

                                        string gioKetThuc = gioKetThucObj?.ToString()?.Length >= 5
                                        ? gioKetThucObj.ToString()!.Substring(0, 5)
                                        : gioKetThucObj?.ToString() ?? "";

                                        var selected = ViewBag.KhungGioIdVal != null && id != null && ViewBag.KhungGioIdVal == (int)id;

                                        <option value="@id" selected="@selected">
                                            @ten (@gioBatDau - @gioKetThuc)
                                        </option>
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Hình thức thanh toán</label>
                        <select class="form-select border-primary" asp-for="HinhThucThanhToan" disabled="@daThanhToan">
                            <option value="">-- Chưa chọn --</option>
                            <option value="Tiền mặt">Tiền mặt 💵</option>
                            <option value="Thẻ">Thẻ ngân hàng 💳</option>
                            <option value="QR">Chuyển khoản QR 📱</option>
                        </select>
                    </div>

                    <div class="d-grid gap-2">
                        <div class="btn-group">
                            <button type="button" class="btn btn-outline-warning" id="btnUndo" @(daThanhToan ? "disabled" : "")>Hoàn tác</button>
                            <button type="button" class="btn btn-outline-secondary" id="btnRestore" @(daThanhToan ? "disabled" : "")>Mặc định</button>
                        </div>
                        <button type="submit" class="btn btn-success btn-lg" id="btnSave" @(daThanhToan ? "disabled" : "")>
                            <i class="fa fa-save"></i> CẬP NHẬT HÓA ĐƠN
                        </button>
                        <a class="btn btn-outline-dark" href="@Url.Action("Index", new { status = ViewBag.Status })">Quay lại</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* --- MODAL SƠ ĐỒ BÀN (Giữ nguyên Style của bạn vì nó rất đẹp) --- *@
<div class="modal fade" id="banPhongModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content" style="background:#1a1a1a; color:white; border:1px solid #444;">
            <div class="modal-header border-secondary">
                <h4 class="modal-title text-warning">Sơ đồ Nhà hàng</h4>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-modal-content">
                    <div class="area-entrance">🚪 CỬA VÀO CHÍNH</div>
                    <div class="map-middle-area">
                        <div class="area-window">🪟 VIEW ĐƯỜNG PHỐ</div>
                        <div class="table-map-grid" id="banPhongGrid"></div>
                    </div>
                    <div class="area-kitchen">👨‍🍳 KHU VỰC BẾP & QUẦY BAR</div>
                </div>
                <div class="map-legend">
                    <div class="legend-item"><span class="legend-color available"></span> Trống</div>
                    <div class="legend-item"><span class="legend-color occupied"></span> Bận</div>
                    <div class="legend-item"><span class="legend-color selected"></span> Đang chọn</div>
                </div>
            </div>
        </div>
    </div>
</div>

@* --- SCRIPTS --- *@
@section Scripts {
    <script>
        // 1. Khởi tạo dữ liệu
        let originalItems = [];
        document.querySelectorAll("#itemsBody tr").forEach(tr => {
            originalItems.push({
                MonAnID: Number(tr.dataset.id),
                TenMon: tr.dataset.ten,
                DonGia: Number(tr.dataset.gia),
                SoLuong: Number(tr.dataset.sl)
            });
        });

        const originalState = {
            date: document.getElementById("txtNgayDen").value,
            time: document.getElementById("ddlKhungGio").value,
            tableId: document.getElementById("selectedBanPhongID").value,
            tableName: document.getElementById("selectedBanPhongName").value
        };

        let currentItems = JSON.parse(JSON.stringify(originalItems));
        let undoStack = [];

        // 2. Hàm hỗ trợ giao diện
        function tinhTien() {
            let sub = currentItems.reduce((acc, i) => acc + (i.SoLuong * i.DonGia), 0);
            let vat = sub * 0.10;
            let final = sub + vat;
            document.getElementById("subTotal").innerText = sub.toLocaleString() + "đ";
            document.getElementById("vat").innerText = vat.toLocaleString() + "đ";
            document.getElementById("finalTotal").innerText = final.toLocaleString() + "đ";
        }

        function renderItems() {
            const body = document.getElementById("itemsBody");
            body.innerHTML = currentItems.map(item => `
                <tr data-id="${item.MonAnID}">
                    <td>${item.TenMon}</td>
                    <td class="text-center">
                        <div class="d-flex justify-content-center align-items-center">
                            <button type="button" class="btn btn-sm btn-outline-secondary px-2 btn-minus">-</button>
                            <span class="mx-3 fw-bold">${item.SoLuong}</span>
                            <button type="button" class="btn btn-sm btn-outline-secondary px-2 btn-plus">+</button>
                        </div>
                    </td>
                    <td class="text-end">${item.DonGia.toLocaleString()}đ</td>
                    <td class="text-end fw-bold">${(item.SoLuong * item.DonGia).toLocaleString()}đ</td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger btn-remove-all">Xóa</button></td>
                </tr>
            `).join('');
            tinhTien();
        }

        // 3. Sự kiện thay đổi món ăn
        document.getElementById("itemsBody").addEventListener("click", function(e) {
            const row = e.target.closest("tr");
            if (!row) return;
            const id = Number(row.dataset.id);
            const item = currentItems.find(x => x.MonAnID === id);

            if (e.target.classList.contains("btn-minus") || e.target.classList.contains("btn-plus") || e.target.classList.contains("btn-remove-all")) {
                undoStack.push({ items: JSON.parse(JSON.stringify(currentItems)) });
            }

            if (e.target.classList.contains("btn-minus") && item.SoLuong > 1) item.SoLuong--;
            else if (e.target.classList.contains("btn-plus")) item.SoLuong++;
            else if (e.target.classList.contains("btn-remove-all")) {
                currentItems = currentItems.filter(x => x.MonAnID !== id);
            }
            renderItems();
        });

        document.getElementById("btnAddItem").addEventListener("click", function() {
            const select = document.getElementById("addItemSelect");
            if (!select.value) return;
            
            undoStack.push({ items: JSON.parse(JSON.stringify(currentItems)) });
            
            const id = Number(select.value);
            const opt = select.options[select.selectedIndex];
            const sl = Number(document.getElementById("addItemSL").value);
            
            const exist = currentItems.find(x => x.MonAnID === id);
            if (exist) exist.SoLuong += sl;
            else currentItems.push({ MonAnID: id, TenMon: opt.dataset.ten, DonGia: Number(opt.dataset.gia), SoLuong: sl });
            
            renderItems();
            select.value = "";
        });

        // 4. Sơ đồ bàn AJAX
        document.querySelector("[data-bs-target='#banPhongModal']").addEventListener("click", function() {
            fetch(`/Invoices/GetBanPhong?hoaDonId=@Model.HoaDonID`)
                .then(res => res.json())
                .then(data => {
                    let html = data.map(b => {
                        const bid = b.banPhongId || b.BanPhongId;
                        const bname = b.tenBanPhong || b.TenBanPhong;
                        const bseat = b.soChoNgoi || b.Sochongoi || 0;
                        const bstatus = b.trangThai || b.TrangThai || "Trống";
                        const isAvailable = (bstatus.toLowerCase() === "trống" || bstatus.toLowerCase() === "trong");
                        
                        return `
                            <div class="table-card ${isAvailable ? 'available' : 'busy'}" 
                                 data-id="${bid}" data-name="${bname}" data-available="${isAvailable}">
                                <div class="table-card-icon"><svg viewBox="0 0 24 24"><path d="M3 10h18v2H3v-2zm2 4h14v6H5v-6zM7 4h10v4H7V4z"/></svg></div>
                                <div class="table-card-name">${bname}</div>
                                <div class="table-card-capacity">${bseat} chỗ</div>
                            </div>`;
                    }).join('');
                    document.getElementById("banPhongGrid").innerHTML = html;
                    
                    // Highlight bàn đang chọn
                    const currentId = document.getElementById("selectedBanPhongID").value;
                    const activeCard = document.querySelector(`.table-card[data-id="${currentId}"]`);
                    if (activeCard) activeCard.classList.add("selected");
                });
        });

        document.getElementById("banPhongGrid").addEventListener("click", function(e) {
            const card = e.target.closest(".table-card");
            if (!card || card.dataset.available !== "true") return;

            document.getElementById("selectedBanPhongID").value = card.dataset.id;
            document.getElementById("selectedBanPhongName").value = card.dataset.name;
            bootstrap.Modal.getInstance(document.getElementById('banPhongModal')).hide();
        });

        // 5. Hoàn tác & Lưu
        document.getElementById("btnUndo").addEventListener("click", function() {
            if (undoStack.length > 0) {
                const prev = undoStack.pop();
                currentItems = prev.items;
                renderItems();
            }
        });

        document.getElementById("btnSave").addEventListener("click", function(e) {
            e.preventDefault();
            const jsonInput = document.createElement("input");
            jsonInput.type = "hidden";
            jsonInput.name = "ItemsJson";
            jsonInput.value = JSON.stringify(currentItems);
            document.getElementById("paymentForm").appendChild(jsonInput);
            document.getElementById("paymentForm").submit();
        });

        renderItems(); 
    </script>
}