@model Quanlinhahang.Data.Models.Hoadon

@{
    ViewData["Title"] = $"Hóa Đơn #{Model.Hoadonid}";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index");
}

<h2 class="mt-3">Hóa Đơn #@Model.Hoadonid</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <h5>Thông tin chung</h5>
        <dl class="row">

            <dt class="col-sm-5">Ngày lập</dt>
            <dd class="col-sm-7">@Model.Ngaylap.ToString("dd/MM/yyyy HH:mm")</dd>

            <dt class="col-sm-5">Trạng thái</dt>
            <dd class="col-sm-7">@(Model.Trangthai?.Tentrangthai ?? "---")</dd>

            <dt class="col-sm-5">Hình thức thanh toán</dt>
            <dd class="col-sm-7">@(Model.Hinhthucthanhtoan ?? "Tiền mặt")</dd>

            <dt class="col-sm-5">Mã Đặt bàn</dt>
            <dd class="col-sm-7">
                @if (Model.Datban != null)
                {
                    <a href="@Url.Action("Details", "Datbans", new { id = Model.Datbanid })">#@Model.Datbanid</a>
                }
                else
                {
                    <span>Khách vãng lai</span>
                }
            </dd>

            <dt class="col-sm-5">Loại bàn / phòng</dt>
            <dd class="col-sm-7">
                @(Model.Datban?.Banphong?.Loaibanphong != null
                                ? Model.Datban.Banphong.Loaibanphong.Tenloai // Sửa: TenLoai -> Tenloai
                                : "Không yêu cầu")
            </dd>

            <dt class="col-sm-5">Nhân viên lập</dt>
            <dd class="col-sm-7">@Model.Taikhoanid</dd>

        </dl>
    </div>

    <div class="col-md-7">
        <h5>Danh sách món</h5>
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Tên món</th>
                    <th class="text-end">SL</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Chitiethoadons != null)
                {
                    foreach (var item in Model.Chitiethoadons)
                    {
                        <tr>
                            <td>@(item.Monan?.Tenmon ?? "Món đã xóa")</td>

                            <td class="text-end">@item.Soluong</td>

                            <td class="text-end">@item.Dongia.ToString("#,##0")</td>

                            <td class="text-end">@((item.Soluong * item.Dongia).ToString("#,##0"))</td>
                        </tr>
                    }
                }
            </tbody>

            <tfoot class="table-light">
                @{
                    // Sửa logic tính tổng: Dùng (Soluong * Dongia) thay vì thuộc tính ThanhTien
                    decimal subTotal = 0;
                    if (Model.Chitiethoadons != null)
                    {
                        subTotal = Model.Chitiethoadons.Sum(i => i.Soluong * i.Dongia);
                    }

                    var vat = subTotal * 0.1m; // VAT 10% (tùy chỉnh nếu cần)
                    var finalTotal = (subTotal + vat);
                    if (finalTotal < 0) finalTotal = 0;
                }
                <tr>
                    <td colspan="3" class="text-end">Tạm tính:</td>
                    <td class="text-end">@subTotal.ToString("#,##0")</td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end">VAT (10%):</td>
                    <td class="text-end">@vat.ToString("#,##0")</td>
                </tr>

                <tr class="h5">
                    <td colspan="3" class="text-end"><strong>Thành tiền:</strong></td>
                    <td class="text-end"><strong>@finalTotal.ToString("#,##0")</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<hr />

<div class="text-end">
    <a href="@Url.Action("Print", new { id = Model.Hoadonid })" target="_blank" class="btn btn-warning me-2">
        In hóa đơn
    </a>

    <a class="btn btn-secondary" href="@returnUrl">
        Quay lại
    </a>
</div>