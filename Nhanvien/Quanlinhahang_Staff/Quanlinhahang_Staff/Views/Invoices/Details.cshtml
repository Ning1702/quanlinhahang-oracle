@model Quanlinhahang.Data.Models.HoaDon

@{
    ViewData["Title"] = $"Hóa Đơn #{Model.HoaDonId}";
    var returnUrl = ViewBag.ReturnUrl as string ?? Url.Action("Index");
}

<h2 class="mt-3">Hóa Đơn #@Model.HoaDonId</h2>
<hr />

<div class="row">
    <div class="col-md-5">
        <h5>Thông tin chung</h5>
        <dl class="row">

            <dt class="col-sm-5">Ngày lập</dt>
            <dd class="col-sm-7">@(Model.NgayLap?.ToString("dd/MM/yyyy HH:mm") ?? "---")</dd>

            <dt class="col-sm-5">Trạng thái</dt>
            <dd class="col-sm-7">@(Model.TrangThai?.TenTrangThai ?? "---")</dd>

            <dt class="col-sm-5">Hình thức thanh toán</dt>
            <dd class="col-sm-7">Tiền mặt</dd>

            <dt class="col-sm-5">Mã Đặt bàn</dt>
            <dd class="col-sm-7">
                @if (Model.DatBanId != null)
                {
                    <a href="@Url.Action("Details", "DatBans", new { id = Model.DatBanId })">#@Model.DatBanId</a>
                }
                else
                {
                    <span>Khách vãng lai</span>
                }
            </dd>

            <dt class="col-sm-5">Bàn / Phòng</dt>
            <dd class="col-sm-7">
                @(Model.DatBan?.BanPhong != null
                                ? Model.DatBan.BanPhong.TenBanPhong
                                : "Không yêu cầu")
            </dd>

            <dt class="col-sm-5">Nhân viên lập (ID)</dt>
            <dd class="col-sm-7">@Model.TaiKhoanId</dd>

        </dl>
    </div>

    <div class="col-md-7">
        <h5>Danh sách món</h5>
        <table class="table table-bordered table-sm">
            <thead class="table-light">
                <tr>
                    <th>Tên món</th>
                    <th class="text-end">SL</th>
                    <th class="text-end">Đơn giá</th>
                    <th class="text-end">Thành tiền</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.ChiTietHoaDons != null)
                {
                    foreach (var item in Model.ChiTietHoaDons)
                    {
                        <tr>
                            <td>@(item.MonAn?.TenMon ?? "Món đã xóa")</td>
                            <td class="text-end">@item.SoLuong</td>
                            <td class="text-end">@item.DonGia?.ToString("#,##0")</td>
                            <td class="text-end">@((item.SoLuong * (item.DonGia ?? 0))?.ToString("#,##0"))</td>
                        </tr>
                    }
                }
            </tbody>

            <tfoot class="table-light">
                @{
                    decimal subTotal = 0;
                    if (Model.ChiTietHoaDons != null)
                    {
                        subTotal = Model.ChiTietHoaDons.Sum(i => (decimal)(i.SoLuong * (i.DonGia ?? 0)));
                    }

                    // Sử dụng cột Vatpercent từ DB (ví dụ: 10 đại diện cho 10%)
                    var vatPercent = Model.Vatpercent ?? 10m;
                    var vatAmount = subTotal * (vatPercent / 100m);
                    var finalTotal = subTotal + vatAmount;
                }
                <tr>
                    <td colspan="3" class="text-end">Tạm tính:</td>
                    <td class="text-end">@subTotal.ToString("#,##0")</td>
                </tr>
                <tr>
                    <td colspan="3" class="text-end">VAT (@vatPercent%):</td>
                    <td class="text-end">@vatAmount.ToString("#,##0")</td>
                </tr>

                <tr class="h5">
                    <td colspan="3" class="text-end"><strong>Thành tiền:</strong></td>
                    <td class="text-end"><strong>@(Model.TongTien?.ToString("#,##0") ?? finalTotal.ToString("#,##0"))</strong></td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>

<hr />

<div class="text-end">
    <a href="@Url.Action("Print", new { id = Model.HoaDonId })" target="_blank" class="btn btn-warning me-2">
        In hóa đơn
    </a>

    <a class="btn btn-secondary" href="@returnUrl">
        Quay lại
    </a>
</div>