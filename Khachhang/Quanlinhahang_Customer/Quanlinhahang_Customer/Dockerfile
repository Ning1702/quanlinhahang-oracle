FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY . .

WORKDIR /src/Khachhang/Quanlinhahang_Customer/Quanlinhahang_Customer
RUN dotnet restore "Quanlinhahang_Customer.csproj"
RUN dotnet publish "Quanlinhahang_Customer.csproj" -c Release -o /app/publish /p:UseAppHost=false

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

ENV ASPNETCORE_URLS=http://+:10000
EXPOSE 10000

ENTRYPOINT ["dotnet", "Quanlinhahang_Customer.dll"]
